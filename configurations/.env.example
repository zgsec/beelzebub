# =============================================================================
# Beelzebub Canary Token Reference
# =============================================================================
# Each service uses unique canary tokens from canarytokens.org.
# Tokens fire alerts when attackers use discovered credentials or resolve
# honeypot DNS names. Deploy with different tokens per sensor.
#
# IMPORTANT: Beelzebub does NOT interpolate ${VAR} in YAML configs.
# Tokens must be hardcoded directly in each sensor's prod config files.
# This file documents which tokens each service needs.
#
# 8 services across 8 ports per sensor (as of 2026-03-09).
# =============================================================================

# --- Open WebUI (HTTP) :8888 ---
HTTP_CANARY_AWS_KEY=HONEYTOKEN00EXAMPLE02
HTTP_CANARY_AWS_SECRET=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
HTTP_CANARY_DNS=example.canarytokens.com
HTTP_CANARY_WEB_BUG=http://canarytokens.com/example/http

# --- Ollama :11434 ---
OLLAMA_CANARY_URL=https://docs.internal.example.com
OLLAMA_CANARY_AWS_KEY=HONEYTOKEN00EXAMPLE03
OLLAMA_CANARY_AWS_SECRET=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
OLLAMA_CANARY_DNS=svc-mesh.int.example.io
OLLAMA_CANARY_EMAIL=platform-alerts@example.io

# --- OpenAI-compatible API :8001 ---
OPENAI_CANARY_AWS_KEY=HONEYTOKEN00EXAMPLE04
OPENAI_CANARY_AWS_SECRET=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
OPENAI_CANARY_AWS_KEY_ML=HONEYTOKEN00EXAMPLE05
OPENAI_CANARY_AWS_SECRET_ML=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
OPENAI_CANARY_DNS=example.canarytokens.com
OPENAI_CANARY_WEB_BUG=http://canarytokens.com/example/openai
OPENAI_CANARY_WEB_BUG_MCP=http://canarytokens.com/example/openai-mcp

# --- OpenClaw Gateway :18789 ---
OPENCLAW_CANARY_AWS_KEY=HONEYTOKEN00EXAMPLE06
OPENCLAW_CANARY_AWS_SECRET=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
OPENCLAW_CANARY_DNS=example.canarytokens.com

# --- SSH Shell Emulator :22 / :2222 ---
# The shell emulator DOES expand ${VAR} via os.ExpandEnv at runtime.
# Set these in the sensor's .env file for per-sensor attribution.
# Without them, defaults (AKIAIOSFODNN7EXAMPLE etc.) are used.
CANARY_SSH_AWS_KEY=HONEYTOKEN00EXAMPLE07
CANARY_SSH_AWS_SECRET=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
CANARY_SSH_API_KEY=sk-live-example-canary-key
CANARY_SSH_DB_PASSWORD=canary-db-password-example
CANARY_SSH_DNS=example.canarytokens.com
CANARY_SSH_DOCKER_AUTH=ZXhhbXBsZTpjYW5hcnktZG9ja2VyLWF1dGg=

# --- MCP :8000 (uses CANARYTOKEN_* placeholders in prod configs) ---
# MCP tokens are replaced at deploy time in per-sensor prod configs.
# See configurations/prod-configs/mcp-8000-{ewr,fra}.yaml

# --- MySQL :3306 ---
# Banner-only service, no canary tokens needed.
