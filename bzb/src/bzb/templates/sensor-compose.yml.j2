# Generated by bzb render. Do not hand-edit; rerun bzb render.
services:
  beelzebub:
    image: ghcr.io/{{ image_org }}/beelzebub-fork:{{ image_tag }}
    container_name: beelzebub
    restart: unless-stopped
    network_mode: host
    volumes:
      - ./persona:/configurations:ro
      - beelzebub-logs:/var/log/beelzebub
    environment:
      - SENSOR_ID=${SENSOR_ID}
      - PERSONA_SLUG=${PERSONA_SLUG}
      - OPEN_AI_SECRET_KEY=${OPEN_AI_SECRET_KEY}
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

  exporter:
    image: ghcr.io/{{ image_org }}/honeypot-exporter:{{ image_tag }}
    container_name: honeypot-exporter
    restart: unless-stopped
    read_only: true
    security_opt:
      - no-new-privileges:true
    tmpfs:
      - /tmp:size=10M
    volumes:
      - beelzebub-logs:/var/log/beelzebub:ro
      - ./geoip:/geoip:ro
      - exporter-data:/data
      - p0f-log:/var/log/p0f:ro
    environment:
      - LOG_PATH=/var/log/beelzebub/beelzebub.log
      - GEOIP_COUNTRY=/geoip/GeoLite2-Country.mmdb
      - GEOIP_ASN=/geoip/GeoLite2-ASN.mmdb
      - DATA_PATH=/data
      - SENSOR_ID=${SENSOR_ID}
      - IP_SALT=${IP_SALT}
      - AGGREGATOR_URL=${AGGREGATOR_URL}
      - AGGREGATOR_TOKEN=${AGGREGATOR_TOKEN}
      - P0F_LOG_PATH=/var/log/p0f/p0f.log
      {%- for k in extra_exporter_env %}
      - {{ k }}=${{ '{' }}{{ k }}{{ '}' }}
      {%- endfor %}

  p0f:
    image: ghcr.io/{{ image_org }}/p0f:{{ p0f_tag }}
    container_name: p0f
    restart: unless-stopped
    network_mode: host
    cap_add:
      - NET_RAW
      - NET_ADMIN
    volumes:
      - p0f-log:/var/log/p0f
    command: ["-i", "any", "-o", "/var/log/p0f/p0f.log"]

volumes:
  beelzebub-logs:
  exporter-data:
  p0f-log:
